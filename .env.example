# ── Groq LLM (required for AI recommendations) ───────────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Legacy alias (optional; GROQ_API_KEY is preferred)
# LLM_API_KEY=

# ── Offline / testing modes ───────────────────────────────────────────────────
# Skip Groq; use rule-based fallback rankings instead
# MOCK_LLM=1

# Force re-download of the Zomato dataset (ignores existing cache)
# FORCE_REFRESH_CATALOG=1

# Run live Groq integration test (requires GROQ_API_KEY)
# RUN_LLM_INTEGRATION=1

# ── Recommendation cache (Phase 6) ───────────────────────────────────────────
# How long to cache identical pipeline results (seconds, default 300 / 5 min)
# CACHE_TTL_SECONDS=300

# Set to 1 to disable the result cache entirely
# DISABLE_CACHE=1

# ── FastAPI backend (Phase 7) ─────────────────────────────────────────────────
# Comma-separated allowed CORS origins (default: * for local dev)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Streamlit (set automatically in Docker; override locally if needed) ───────
# STREAMLIT_SERVER_HEADLESS=true
# STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
