# Groq LLM (Phase 3–4)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Legacy alias (optional; GROQ_API_KEY preferred)
# LLM_API_KEY=

# Offline mode: skip Groq, use rule-based fallback rankings
# MOCK_LLM=1

# Optional: force refresh of restaurant catalog cache
# FORCE_REFRESH_CATALOG=1

# Optional: run live Groq integration test
# RUN_LLM_INTEGRATION=1
